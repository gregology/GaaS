llms:
  default:
    base_url: "http://10.0.0.31:8000"
    model: "glm-4.7-flash:30b-gpu"
    parameters:
      temperature: 0.7
  smart:
    base_url: "http://10.0.0.31:8000"
    model: "qwen3.5:397b"
    parameters: {}
  fast:
    base_url: "http://10.0.0.21:11434"
    model: "glm-4.7-flash:latest"
    parameters:
      temperature: 0.7
  external:
    base_url: "https://api.openai.com"
    token: !secret openai_api_key
    model: "gpt-5-mini-2025-08-07"

integrations:
- type: email
  name: personal
  imap_server: imap.fastmail.com
  imap_port: 993
  username: greg@fea.st
  password: !secret email_password
  schedule:
    every: 15m
  llm: fast
  platforms:
    inbox:
      limit: 3
      classifications:
        human: is this a personal email written by a human?
        robot: is this email from an automated system?
        requires_response:
          prompt: does this email require a response?
          type: boolean
        urgency:
          prompt: how urgent is this email?
          type: enum
          values: [none, low, medium, high, critical]
        user_agreement_update:
          prompt: is this email only to tell me that a user agreement has been 
            updated?
          type: boolean
        # automations:
        #   - when:
        #       classification.user_agreement_update: true
        #     then:
        #       - archive
        #   - when:
        #       classification.robot: 0.8
        #       classification.human: "< 0.2"
        #       classification.requires_response: false
        #       is_calendar_event: false
        #     then: archive
        #   - when:
        #       calendar.end: "<now()"
        #     then: archive
- type: github
  name: personal
  schedule:
    every: 10m
  llm: fast
    # orgs: [myorg, anotherorg]       # Restrict to specific GitHub organizations
    # repos: [myorg/myrepo]           # Restrict to specific repositories (org/repo)
  platforms:
    pull_requests:
        # include_mentions: true      # Also track PRs that mention you (noisy, off by default)
      classifications:                # Optional — defaults are used if omitted
        complexity: how complex is this PR to review? 0 = trivial typo fix, 1 = 
          major architectural change
        risk: how risky is this change? 0 = no risk, 1 = high risk of breaking 
          things
        documentation_only:
          prompt: is this primarily a documentation or configuration change?
          type: boolean
    issues:
      include_mentions: true
      classifications:
        urgency: how urgently does this issue need attention?
        actionable:
          prompt: can you take a concrete next step on this issue?
          type: boolean


directories:
  notes: /Users/greg/Documents/Greg_test
  task_queue: /Users/greg/Documents/Greg_test_queue
  logs: /Users/greg/Documents/Greg_test/gaas_logs
scripts:
  foo:
    shell: "echo hello world\necho hey world"
    description: 'baz'
    timeout: 120
    inputs: []
    output:
    on_output: human_log
    reversible: false
